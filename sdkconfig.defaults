CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n

# 优化固件体积
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# ===== 硬件规格：ESP32-C5-WROOM-1-N16R8 (16MB Flash + 8MB PSRAM) =====
# Flash 大小设为 16MB
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# 启用 PSRAM（8MB），供音频缓冲、RTC SDK 大块内存使用
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y
# 允许 malloc 在内部 RAM 不足时回退到 PSRAM
CONFIG_SPIRAM_USE_MALLOC=y
# 大于该阈值的分配优先走 PSRAM，保护内部 RAM
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y

# ===== 分区表：使用自定义大 app 分区，容纳 RTC 静态库 =====
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# ===== Wi-Fi 默认连接配置 =====
CONFIG_ESP_WIFI_SSID="Redmi_B3D4_5G"
CONFIG_ESP_WIFI_PASSWORD="88888888"

# ===== OneNET MQTT 凭证（控制台获取） =====
CONFIG_ONENET_PRODUCT_ID="Kt5Z8Eph6q"
CONFIG_ONENET_DEVICE_NAME="zhixin_001"
CONFIG_ONENET_DEVICE_TOKEN="YXIwRUR2a1dnUEdvd21NczJVTHZRaGU3TkRVTGNaajc="
